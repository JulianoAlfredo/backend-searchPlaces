# ─── Google Maps Places API ──────────────────────────────────────────────────
# Obrigatória para a busca real. Sem ela, o backend roda em modo demonstração.
# Crie em https://console.cloud.google.com/ → ative a "Places API" → gere a chave.
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ─── OpenAI (opcional) ────────────────────────────────────────────────────────
# Habilita o diagnóstico com IA (gpt-4o-mini). Sem ela, usa-se a análise local.
OPENAI_API_KEY=

# ─── Servidor ─────────────────────────────────────────────────────────────────
# Porta do backend local (default: 3001). Ignorada quando rodando na Vercel.
PORT=3001
